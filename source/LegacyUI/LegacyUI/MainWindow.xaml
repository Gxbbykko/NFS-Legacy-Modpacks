<Window x:Class="LegacyUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Legacy UI"
        Height="610"
        Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#101014">

    <Grid>
        <Border Margin="24"
                CornerRadius="18"
                Background="#181820"
                BorderBrush="#2E2E3A"
                BorderThickness="1">

            <Grid Margin="34">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="TitleText"
                               Text="Legacy Modpack"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"/>

                    <TextBlock x:Name="SubtitleText"
                               Text="Preparing installer..."
                               Foreground="#B9B9C8"
                               FontSize="15"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,38,0,38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.35*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="StageText"
                                   Text="Waiting for install activity..."
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="DetailText"
                                   Text="LegacyUI is monitoring the selected game directory."
                                   Foreground="#A8A8B8"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Width="470"
                                   Margin="0,0,0,28"/>

                        <TextBlock x:Name="ActivityText"
                        Text="Preparing file operations..."
                        Foreground="#7FCBFF"
                        FontSize="14"
                        FontFamily="Consolas"
                        TextWrapping="Wrap"
                        Width="470"
                        Margin="0,0,0,22"/>

                        <TextBlock x:Name="CurrentFileText"
                        Text="Waiting for file activity..."
                        Foreground="#9A9AB0"
                        FontSize="13"
                        FontFamily="Consolas"
                        TextWrapping="Wrap"
                        Width="470"
                        Margin="0,0,0,22"/>

                        <Border Height="22"
                                Width="470"
                                CornerRadius="9"
                                Background="#2A2A34"
                                HorizontalAlignment="Left">
                            <Grid>
                                <Border x:Name="ProgressFill"
                                        Width="0"
                                        CornerRadius="9"
                                        Background="#3FA7FF"
                                        HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="PercentText"
                                   Text="0%"
                                   Foreground="#DADAEA"
                                   FontSize="14"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            CornerRadius="14"
                            Background="#111118"
                            BorderBrush="#2E2E3A"
                            BorderThickness="1"
                            Padding="22">

                        <StackPanel>
                            <TextBlock Text="Telemetry"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18"/>

                            <TextBlock x:Name="ModeText"
                                       Text="Mode: install"
                                       Foreground="#B9B9C8"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <TextBlock x:Name="ElapsedText"
                                       Text="Elapsed: 0.0s"
                                       Foreground="#B9B9C8"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <TextBlock x:Name="SizeText"
                                       Text="Folder size: 0 MB"
                                       Foreground="#B9B9C8"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <TextBlock x:Name="FileCountText"
                                       Text="Files: 0"
                                       Foreground="#B9B9C8"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <TextBlock x:Name="ManifestText"
                                       Text="Manifest lines: 0"
                                       Foreground="#B9B9C8"
                                       FontSize="14"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Installer engine is running in the background. Do not close this window."
                           Foreground="#77778A"
                           FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Window>