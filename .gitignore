```gitignore
# =========================================================
# NFS Legacy Modpacks - Release 2.0
# .gitignore
#
# Excludes build artifacts, generated files, temporary data,
# installer payloads and local development files while keeping
# all source code and documentation under version control.
# =========================================================

# =========================================================
# Build outputs
# =========================================================

Build/
Output/
Compiled/
Release/
Debug/
publish/
artifacts/

bin/
obj/

**/bin/
**/obj/
**/publish/

# =========================================================
# Installer binaries / compiled executables
# =========================================================

*.exe
*.msi
*.dll
*.pdb
*.app
*.appx
*.msix
*.lib
*.exp
*.ilk
*.iobj
*.ipdb

# =========================================================
# Compressed archives / payloads
# =========================================================

*.arc
*.zip
*.7z
*.rar
*.tar
*.gz

# =========================================================
# Large generated installer folders
# =========================================================

source/SetupLauncher/Backend/
source/SetupLauncher/bin/
source/SetupLauncher/obj/

InstallerProject/
_backend/
_DEBUG_RUN/

# =========================================================
# Temporary extraction / installer runtime data
# =========================================================

_LegacyInstaller/
RestoreData/
Backup/
*_Extract/

arc_progress.log
install_error.txt
LegacyUI_crash.log

# =========================================================
# Rollback validation files
# =========================================================

baseline_vanilla.csv
after_install.csv
after_uninstall.csv
telemetry_*.csv

# =========================================================
# Local testing folders
# =========================================================

Test/
TestBackup/
TestEmpty/
TestFolder/
Sandbox/
Scratch/

# =========================================================
# Temporary files
# =========================================================

*.tmp
*.temp
*.bak
*.old
*.orig
*.part
*.tmp.arc

# =========================================================
# Windows / macOS generated files
# =========================================================

Thumbs.db
Desktop.ini
.DS_Store

# =========================================================
# IDE / editor settings
# =========================================================

.vs/
.vscode/
.idea/

*.suo
*.user
*.cache
*.userosscache
*.sln.docstates
*.code-workspace

_ReSharper*/
*.DotSettings.user

# =========================================================
# NuGet / .NET
# =========================================================

packages/
*.nupkg

# =========================================================
# Python cache
# =========================================================

__pycache__/
*.pyc

# =========================================================
# Game-generated configuration / diagnostic files
# =========================================================

nextgenfx_settings.ini
d3d9.ini
dxvk.conf
reshade.ini
*.log

# =========================================================
# Source-control placeholders
# =========================================================

!**/.gitkeep

# =========================================================
# Repository notes
# =========================================================
#
# Gallery screenshots inside:
#
#   releases/**/Gallery/
#   screenshots/
#
# are intentionally version-controlled as part of the Release
# 2.0 documentation and validation proof. They must NOT be
# ignored.
#
# Compiled installers, archives and generated runtime files
# are intentionally excluded from this repository.
#
# Public releases are distributed through GitHub Releases and
# Nexus Mods.
```
